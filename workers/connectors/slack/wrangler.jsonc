{
  "name": "openchief-connector-slack",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-01",
  "queues": {
    "producers": [
      {
        "queue": "openchief-events",
        "binding": "EVENTS_QUEUE"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "openchief-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "services": [
    {
      "binding": "AGENT_RUNTIME",
      "service": "openchief-runtime"
    }
  ],
  "triggers": {
    "crons": ["*/30 * * * *"]
  }
  // Secrets (set via `wrangler secret put`):
  //   SLACK_BOT_TOKEN
  //   SLACK_SIGNING_SECRET
  //   ADMIN_SECRET
  //   RUNTIME_ADMIN_SECRET — must match runtime's ADMIN_SECRET (for AI chat)
}
