{
  "name": "openchief-connector-notion",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-30",
  "kv_namespaces": [
    {
      "binding": "POLL_CURSOR",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "EVENTS_QUEUE",
        "queue": "openchief-events"
      }
    ]
  },
  "triggers": {
    "crons": ["*/15 * * * *"]
  }
}
